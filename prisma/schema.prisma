generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Course {
  id          String    @id @default(uuid())
  title       String    @unique
  description String?
  authorId    String
  slug        String    @unique

  sections    Section[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Section {
  id        String   @id @default(uuid())
  title     String
  courseId  String
  slug      String   @unique

  course    Course   @relation(fields: [courseId], references: [id])
  lessons   Lesson[]

  order     Int

  createdAt DateTime @default(now())

  @@unique([courseId, title])
  @@unique([courseId, slug])
}


model Lesson {
  id        String   @id @default(uuid())
  title     String
  content   Json
  sectionId String
  slug      String
  section   Section  @relation(fields: [sectionId], references: [id])


  order     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, title])
  @@unique([sectionId, slug])
}